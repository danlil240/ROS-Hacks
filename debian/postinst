#!/bin/sh
set -e

case "$1" in
    configure)
        echo "Creating symbolic link: /usr/bin/ros-hacks-setup -> /usr/share/ros-hacks/setup.sh"
        ln -sf /usr/share/ros-hacks/setup.sh /usr/bin/ros-hacks-setup
        echo "Creating symbolic link: /usr/bin/ros-hacks-setup-p10k -> /usr/share/ros-hacks/scripts/setup-p10k.zsh"
        ln -sf /usr/share/ros-hacks/scripts/setup-p10k.zsh /usr/bin/ros-hacks-setup-p10k
        ;;
    
    abort-upgrade|abort-remove|abort-deconfigure)
        # No special action needed
        ;;

    *)
        echo "postinst called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
